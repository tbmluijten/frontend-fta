{
  "name": "fta-landing-wp-theme",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss ./src/theme-input.css -o ./assets/css/app.css",
    "build:js": "esbuild ./src/main.js --bundle --outfile=./assets/js/main.js --minify"
  },
  "dependencies": {
    "embla-carousel": "^8.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^4"
  }
}
